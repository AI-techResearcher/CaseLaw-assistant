# Copy this file to .env and fill in real values. NEVER commit the real .env.

# --- Weaviate Cloud (vector database) ---
WEAVIATE_URL=https://your-cluster.weaviate.cloud
WEAVIATE_API_KEY=your-weaviate-api-key
# Collection / class name that holds the indexed legal documents.
WEAVIATE_CLASS=JustiaFederalCases

# --- OpenAI (LLM) ---
OPENAI_API_KEY=your-openai-api-key
# Optional override:
OPENAI_MODEL=gpt-4o-mini

# --- Web server ---
# Comma-separated list of allowed CORS origins. Use specific origins in
# production, e.g. https://app.example.com
ALLOWED_ORIGINS=*
